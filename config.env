# Claude Powers 配置文件
# 安装前请填写以下信息

# === 必填 ===
# 你的名字（用于 Claude 称呼你）
USER_NAME="你的名字"

# Claude Code 记忆空间 ID（英文，唯一标识）
USER_ID="your-username"

# === Anthropic API（用于 LLM 摘要 + EverMemOS 记忆提取）===
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com"

# === 可选 ===
# 时区
TIMEZONE="Asia/Shanghai"

# Claude Code 默认模型 (sonnet / opus / haiku)
DEFAULT_MODEL="sonnet"
