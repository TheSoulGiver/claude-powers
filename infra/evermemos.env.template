# EverMemOS 环境配置模板
# 复制为 .env 后编辑

# === LLM（用于记忆提取和摘要）===
LLM_PROVIDER=openai
LLM_MODEL=claude-haiku-4-5-20251001
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=__ANTHROPIC_API_KEY__
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=32768

# === Embedding（向量化）===
# 方案 A: 本地 Ollama（推荐，免费）
VECTORIZE_PROVIDER=vllm
VECTORIZE_API_KEY=EMPTY
VECTORIZE_BASE_URL=http://localhost:11434/v1
VECTORIZE_MODEL=qwen3-embedding
VECTORIZE_DIMENSIONS=1024

# 方案 B: 云端 API（如果不想跑 Ollama）
# VECTORIZE_PROVIDER=openai
# VECTORIZE_API_KEY=your-openai-key
# VECTORIZE_BASE_URL=https://api.openai.com/v1
# VECTORIZE_MODEL=text-embedding-3-small
# VECTORIZE_DIMENSIONS=1536

VECTORIZE_FALLBACK_PROVIDER=none

# === Rerank ===
RERANK_PROVIDER=none

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=8

# === MongoDB ===
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=memsys123
MONGODB_DATABASE=memsys
MONGODB_URI_PARAMS=socketTimeoutMS=15000&authSource=admin

# === Elasticsearch ===
ES_HOSTS=http://localhost:19200
ES_VERIFY_CERTS=false
SELF_ES_INDEX_NS=memsys

# === Milvus ===
MILVUS_HOST=localhost
MILVUS_PORT=19530
SELF_MILVUS_COLLECTION_NS=memsys

# === API ===
API_BASE_URL=http://localhost:1995
EVERMEMOS_API_KEY=__EVERMEMOS_API_KEY__

# === App ===
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
JWT_SECRET_KEY=__JWT_SECRET__
ACCESS_TOKEN_EXPIRE_MINUTES=30
LLM_MAX_CONCURRENT=3
